        '  request\n' +
        '}) => {\n' +
        '  console.log("===================POST CALL ==============");\n' +
        '\n' +
        '  //step 1 : Create a user:\n' +
        '  const requestBody = {\n' +
        '    name: "PW Test User",\n' +
        '    email: `pwtest${Date.now()}@mail.com`,\n' +
        '    gender: "female",\n' +
        '    status: "active"\n' +
        '  };\n' +
        '  const responsePOST = await request.post(BASE_URL, {\n' +
        '    headers,\n' +
        '    data: requestBody\n' +
        '  });\n' +
        '  (0, _test.expect)(responsePOST.status()).toBe(201);\n' +
        '  const createdUser = await responsePOST.json();\n' +
        '  console.log(createdUser);\n' +
        '  const userId = createdUser.id;\n' +
        '  console.log("Created User ID: " + userId);\n' +
        '  console.log("User is created successfully...");\n' +
        '  console.log("===================GET CALL ==============");\n' +
        '\n' +
        '  //step 2: Get the same user by using user id = userId\n' +
        '\n' +
        '  const responseGET = await request.get(BASE_URL + "/" + userId, {\n' +
        '    headers\n' +
        '  });\n' +
        '  (0, _test.expect)(responseGET.status()).toBe(200);\n' +
        '  const data = await responseGET.json();\n' +
        '  console.log(data);\n' +
        '  console.log("===================UPDATE CALL ==============");\n' +
        '\n' +
        '  //step 3: Update the same user by using user id = userId\n' +
        '\n' +
        '  const updateBody = {\n' +
        '    name: "PW Test Automation User",\n' +
        '    status: "inactive"\n' +
        '  };\n' +
        '  const responsePUT = await request.put(`${BASE_URL}/${userId}`, {\n' +
        '    headers,\n' +
        '    data: updateBody\n' +
        '  });\n' +
        '  (0, _test.expect)(responsePUT.status()).toBe(200);\n' +
        '  const upddatedData = await responsePUT.json();\n' +
        '  console.log(upddatedData);\n' +
        '  console.log("User is updated successfully...");\n' +
        '  console.log("===================DELETE CALL ==============");\n' +
        '\n' +
        '  //step 4: Delete the same user by using user id = userId\n' +
        '  const responseDELETE = await request.delete(`${BASE_URL}/${userId}`, {\n' +
        '    headers\n' +
        '  });\n' +
        '  (0, _test.expect)(responseDELETE.status()).toBe(204);\n' +
        '  console.log("User is deleted successfully...");\n' +
        '  console.log("===================GET CALL ==============");\n' +
        '\n' +
        '  //step 5: Get the same user by using user id = userId afetr delete the same user\n' +
